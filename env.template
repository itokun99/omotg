# OMOTG configuration
# Copy this file to ~/.config/omotg/env and fill in your values.

# Required — Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required — Public HTTPS URL for Telegram webhook (e.g. https://example.com:8443/webhook)
TELEGRAM_WEBHOOK_URL=https://your.domain.com:8443/webhook

# Required — Secret token to verify webhook requests (any random string)
TELEGRAM_SECRET_TOKEN=your_random_secret_here

# Required — OpenCode server password
OPENCODE_SERVER_PASSWORD=your_password_here

# Optional — OpenCode server URL (default: http://127.0.0.1:4096)
# OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Optional — Webhook listen port (default: 8443)
# OMOTG_WEBHOOK_PORT=8443

# Optional — MCP SSE server port (default: 9090)
# OMOTG_MCP_PORT=9090

# Optional — Comma-separated whitelist of Telegram chat IDs (empty = allow all)
# OMOTG_ALLOWED_CHAT_IDS=123456789,987654321

# Optional — TLS certificate file path (empty = plain HTTP, for reverse proxy mode)
# Default: ~/.config/omotg/webhook.crt
# Set to empty to disable TLS (e.g., OMOTG_TLS_CERT_FILE=) when behind a reverse proxy
# OMOTG_TLS_CERT_FILE=

# Optional — TLS key file path (empty = plain HTTP, for reverse proxy mode)
# Default: ~/.config/omotg/webhook.key
# Set to empty to disable TLS when behind a reverse proxy
# OMOTG_TLS_KEY_FILE=

# Optional — Session timeout in seconds (default: 300)
# OMOTG_SESSION_TIMEOUT=300

# --- Multi-Bot Multi-Agent (optional) ---
# Aux Telegram bot token -> OMO agent mapping (hard-coded in config.go).
# Primary bot uses TELEGRAM_BOT_TOKEN above and maps to Sisyphus - ultraworker.
#
#   key         env var                      agent                       webhook path
#   ─────────   ───────────────────────────   ────────────────────────   ──────────────────────────
#   primary     TELEGRAM_BOT_TOKEN            Sisyphus - ultraworker      /webhook (legacy)
#   prometheus  OMO_PROMETHEUS_BOT_TOKEN      Prometheus - Plan Builder   /webhook/prometheus
#   atlas       OMO_ATLAS_BOT_TOKEN            Atlas - Plan Executor       /webhook/atlas
#   hephaestus  OMO_HEPHAESTUS_BOT_TOKEN      Hephaestus - Deep Agent     /webhook/hephaestus
#                ↑ NOTE: server-side error as of 2026-06-22; enable once OpenCode server is fixed.
#
# OMO_PROMETHEUS_BOT_TOKEN=
# OMO_ATLAS_BOT_TOKEN=
# OMO_HEPHAESTUS_BOT_TOKEN=
